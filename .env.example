# Copy to `.env` and fill in. Never commit `.env`.

# MySQL connection string (host is provided separately).
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@localhost:3306/deung_pu_idle"

# M8 party relay (docs/party-relay-protocol.md, docs/party-dev-setup.md). Both MUST
# match the same value the relay process itself is started with (`pnpm relay`).
# Leave PARTY_RELAY_URL unset/empty to keep the party feature silently off (no ticket
# is ever minted without it — see src/server/partyTicket.ts).
PARTY_RELAY_SECRET="dev"
PARTY_RELAY_URL="ws://localhost:8090"
