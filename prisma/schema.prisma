// Prisma schema — ดึ๋งปุ๊ Idle Game
// Host: MySQL. Run `pnpm db:generate` after edits; `pnpm db:migrate` to apply.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  saves      SaveState[]
  characters Character[]
}

// A player character (GDD v2: account -> up to 3 characters, each its own
// class/level/save). One SaveState holds the character's versioned progress blob;
// the columns below are DENORMALIZED CACHES for cheap Hall-of-Fame queries — the
// engine save (SaveState.data) remains the source of truth and is re-derivable.
//
// The <=3-per-account limit is enforced at APP level (count where deletedAt IS
// NULL): MySQL has no clean per-account row-count constraint. Soft delete
// (deletedAt) frees the live slot but keeps the row for audit; `id` is a cuid,
// opaque and NEVER reused — safe to use as ownerId for M7 gear item-instances and
// M9 HOF snapshots.
//
// Name uniqueness (RECOMMENDATION): global, case-insensitive (utf8mb4 default
// collation is CI), enforced at APP level among LIVE characters (deletedAt IS
// NULL) — NOT a DB @@unique. Rationale: a hard unique would keep soft-deleted
// names reserved forever (MySQL lacks partial indexes), and app-level lets a
// freed slot free the name. Trade-off: a TOCTOU race on concurrent creates —
// wrap create in a tx / catch. The @@index([name]) keeps the check + future
// name search fast.
model Character {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String     @db.VarChar(24)
  baseClass String     @db.VarChar(16) // engine HeroClass string: swordsman | archer | mage
  level     Int        @default(1) // cache of engine level (re-derivable)
  power     Int        @default(0) // cache of derived combat power for HOF (re-derivable; widen to BigInt if it ever exceeds 2^31)
  // M7.6 "ตีบวก" (Refine): the per-character REFINE MATERIAL counter. UNLIKE
  // level/power above (denormalized re-derivable caches), this is AUTHORITATIVE —
  // it is NOT re-derivable from the save blob. It is minted ONLY by the salvage
  // endpoint (destroy dupes -> +materials) and spent ONLY by the refine endpoint
  // (materials + gold -> attempt a +level), each inside the same tx as the
  // ItemInstance/ItemEvent mutation. The save blob carries a `materials` MIRROR
  // (like the equipped-gear cache): the boot payload overrides it from THIS column
  // on load, and `persistSave` MUST NOT write it back (a client could otherwise
  // grant itself materials via a save). Owned per-character to match item ownership
  // (ItemInstance.ownerId -> Character.id); gold stays MVP-client-authoritative in
  // the save blob until the M5 gold re-derivation lands.
  materials Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime? // soft delete: slot freed, row kept for audit
  // CUTOVER APPLIED: `SaveState.characterId` is now @unique, so this is an
  // effective 1:1 — a character has AT MOST one save row.
  save      SaveState?
  // M7: gear drops are PER CHARACTER (GDD: "ของดรอปจอใครจอมัน"). ownerId of every
  // ItemInstance points here (Character.id, a never-reused cuid).
  items     ItemInstance[]

  @@index([userId]) // list an account's characters
  @@index([userId, deletedAt]) // count/enumerate LIVE slots (<=3 rule)
  @@index([name]) // app-level uniqueness check + future name search
}

// M7 Gear & Drops — the item-instance model. GDD: gear is server-authoritative
// from the FIRST item; item dupe = existential threat. This table stores only
// INSTANCES; item TEMPLATES + stats live in engine config as pure TS data and are
// referenced by `templateId` (so balance tweaks never migrate the DB).
//
// SOURCE OF TRUTH: unlike Character.level/power (denormalized caches), ItemInstance
// is authoritative — it is NOT re-derivable from the save blob. Every row is minted
// server-side inside a transaction that also appends an ItemEvent(minted). Never
// hard-delete: `deletedAt` soft-deletes (destroyed/consumed) so the audit trail
// stays intact. `id` is an opaque cuid, NEVER reused.
//
// equippedSlot enforcement (one item per slot per character): MySQL has no partial
// unique index, but its UNIQUE indexes treat NULLs as DISTINCT — so a plain
// @@unique([ownerId, equippedSlot]) allows UNLIMITED unequipped rows (equippedSlot
// NULL) while permitting AT MOST ONE non-null value per (owner, slot). That IS the
// partial-unique workaround, and it enforces the invariant at the DB layer, not just
// in app code. INVARIANT the backend must uphold: a soft-deleted item (deletedAt set)
// MUST have equippedSlot = NULL (unequip in the same tx as destroy) — otherwise a
// dead row would still occupy a slot in the unique index.
//
// claimKey (idempotency): the drop-claim endpoint sets a deterministic key per claim
// (e.g. `${characterId}:${dropRollId}`). UNIQUE + NULLABLE — a retried/duplicated
// claim request collides on the unique index and CANNOT double-mint; mints without a
// client claim (boss/admin/trade) leave it NULL (NULLs are distinct, so many allowed).
model ItemInstance {
  id           String    @id @default(cuid()) // opaque, never reused
  ownerId      String // -> Character.id (per-character ownership; NOT User)
  owner        Character @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  templateId   String    @db.VarChar(64) // engine item-template key (stats live in TS config)
  origin       String    @db.VarChar(16) // drop | boss | trade | admin
  sourceDetail String?   @db.VarChar(64) // audit: e.g. zone id / boss id / admin note
  equippedSlot String?   @db.VarChar(16) // weapon | armor | NULL(=unequipped)
  // M7.6 "ตีบวก" (Refine): the item's RO-style +level (+0..+REFINE.maxRefine).
  // Additive, default 0 -> every pre-M7.6 row is an unrefined +0 (byte-identical
  // stats). Mutated ONLY by the server-authoritative refine endpoint (the engine
  // never rolls — CLAUDE.md); success -> +1, degrade -> -1, break -> soft-delete.
  refineLevel  Int       @default(0)
  claimKey     String?   @unique // idempotency guard for the drop-claim endpoint
  acquiredAt   DateTime  @default(now())
  deletedAt    DateTime? // soft delete (destroyed/consumed); MUST NULL equippedSlot too
  events       ItemEvent[]

  @@unique([ownerId, equippedSlot]) // partial-unique via MySQL NULL-distinct: <=1 item per slot per owner; also indexes ownerId-prefix inventory reads
  @@index([templateId]) // "how many of template X exist" / codex / anti-dupe audits
}

// M7 anti-dupe backbone — APPEND-ONLY audit trail. Every state change to an item
// (mint / equip / unequip / trade / destroy) writes one row here IN THE SAME TX as
// the ItemInstance mutation. This is the ledger that makes dupes detectable and
// ownership transfers (M9 trading) provable.
//
// CONVENTION — ENFORCED BY CODE REVIEW, NOT THE DB: no code path may ever UPDATE or
// DELETE a row in this table. Inserts only. (Rows are purged only via ON DELETE
// CASCADE when a User account is hard-deleted for GDPR.)
//
// from/toCharacterId are RAW cuid strings, deliberately NOT FKs: an audit ledger must
// be immutable and independent of the entities it references (and mint has no `from`,
// destroy has no `to`). `meta` is a TEXT column holding serialized JSON (opaque, never
// queried in SQL) — kept as text, not a JSON column, to stay light on this high-write
// table.
model ItemEvent {
  id              String       @id @default(cuid())
  itemId          String
  item            ItemInstance @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type            String       @db.VarChar(16) // minted | equipped | unequipped | traded | destroyed | refined | salvaged
  // (M7.6 "ตีบวก": `salvaged` = destroyed-for-materials (meta.yield); `refined` =
  //  a refine attempt (meta {from,to,outcome,cost}; outcome "break" also soft-
  //  deletes the item, so it doubles as the destroy record for that row).
  fromCharacterId String? // raw cuid, no FK (immutable ledger)
  toCharacterId   String? // raw cuid, no FK
  meta            String?      @db.Text // serialized JSON blob (opaque audit context)
  createdAt       DateTime     @default(now())

  @@index([itemId]) // read an item's full history (ordered by createdAt in-memory)
}

// One row per player save slot. `data` holds the versioned SaveData JSON blob
// (see src/engine/state). `lastSeen` drives capped offline-idle earnings.
// `version` mirrors SaveData.version so migrations can target rows by schema age.
//
// Today: exactly one save slot per user, so `userId` is UNIQUE. This is what lets
// `persistSave` upsert by userId (Prisma upsert needs a unique field in `where`).
// A unique constraint also provides the index, so no separate @@index is needed.
//
// M5 CUTOVER APPLIED (see docs/persistence-m5.md): saves are now PER CHARACTER.
// `characterId` is @unique (one save per character) and `userId @unique` is
// DROPPED — an account may hold up to 3 saves (one per live character). `userId`
// keeps a plain @@index for account-scoped queries + the cascade relation.
// `persistSave`/`loadSave` key off `characterId`; the active character is chosen
// via the `activeCharacterId` cookie (src/server/activeCharacter.ts).
//
// Cutover sequence that produced this state:
//   1. Backfill (prisma/backfill-characters.ts): 1 Character per existing save.
//   2. Set SaveState.characterId to that Character.id (verified distinct+non-null).
//   3. This push: characterId -> @unique, DROP userId @unique. (--accept-data-loss)
model SaveState {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // One save per character: @unique makes the load/persist path key off it and
  // provides the index (so no separate @@index needed). Nullable is retained so a
  // soft-deleted character's orphaned save can keep the (now-dangling-but-audited)
  // link; a live save always has it set.
  characterId String?    @unique
  character   Character? @relation(fields: [characterId], references: [id], onDelete: Cascade)
  version     Int
  data        Json
  lastSeen    DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId]) // account-scoped queries + cascade (was covered by @unique before)
}
