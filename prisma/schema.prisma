// Prisma schema — ดึ๋งปุ๊ Idle Game
// Host: MySQL. Run `pnpm db:generate` after edits; `pnpm db:migrate` to apply.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// M8 "Party & Friends": the User row was an ANONYMOUS cookie identity (id = cookie
// value, only id/createdAt). Registration is now an OPTIONAL upgrade layered on the
// SAME row (a guest keeps their characters/saves when they register) — every new
// column below is additive + NULLABLE so all pre-M8 rows read null = still a guest.
// The ONLY hard product validation is a unique email (no verification email is sent);
// `registeredAt` null distinguishes guest from account.
model User {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  // --- M8 account layer (all nullable; null = anonymous guest) ---
  email        String?   @unique // the one hard-unique field in the product (no verification flow)
  passwordHash String?   @db.VarChar(255) // scrypt/bcrypt-style encoded hash string (algo+salt+digest); never the raw password
  displayName  String?   @db.VarChar(24) // account handle, sized like Character.name
  friendCode   String?   @unique @db.VarChar(16) // short human-shareable code (~8 chars); minted by app code at register time
  registeredAt DateTime? // null = still a guest; set when the account layer is claimed
  saves        SaveState[]
  characters   Character[]
  // M8 friend graph (account<->account). Two relation NAMES per table because a User
  // sits on BOTH ends (requester/addressee, from/to) — Prisma needs disambiguation.
  friendRequestsSent     FriendRequest[] @relation("FriendRequestFrom")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestTo")
  friendshipsA           Friendship[]    @relation("FriendshipUserA")
  friendshipsB           Friendship[]    @relation("FriendshipUserB")
  pingsSent              EmojiPing[]     @relation("EmojiPingFrom")
  pingsReceived          EmojiPing[]     @relation("EmojiPingTo")
  partyInvitesSent       PartyInvite[]   @relation("PartyInviteFrom")
  partyInvitesReceived   PartyInvite[]   @relation("PartyInviteTo")
  // M8 Phase 1 party (social container). A user is in AT MOST one party — the
  // 0..1 side of PartyMember.userId @unique; `partiesLed` is the parties this
  // user is the leader of (cascade dissolves a party if the leader's ACCOUNT is
  // hard-deleted — a rare GDPR event, distinct from the app-level leave/promote).
  partyMembership PartyMember? @relation("PartyMembership")
  partiesLed      Party[]      @relation("PartyLeader")
}

// A player character (GDD v2: account -> up to 3 characters, each its own
// class/level/save). One SaveState holds the character's versioned progress blob;
// the columns below are DENORMALIZED CACHES for cheap Hall-of-Fame queries — the
// engine save (SaveState.data) remains the source of truth and is re-derivable.
//
// The <=3-per-account limit is enforced at APP level (count where deletedAt IS
// NULL): MySQL has no clean per-account row-count constraint. Soft delete
// (deletedAt) frees the live slot but keeps the row for audit; `id` is a cuid,
// opaque and NEVER reused — safe to use as ownerId for M7 gear item-instances and
// M9 HOF snapshots.
//
// Name uniqueness (RECOMMENDATION): global, case-insensitive (utf8mb4 default
// collation is CI), enforced at APP level among LIVE characters (deletedAt IS
// NULL) — NOT a DB @@unique. Rationale: a hard unique would keep soft-deleted
// names reserved forever (MySQL lacks partial indexes), and app-level lets a
// freed slot free the name. Trade-off: a TOCTOU race on concurrent creates —
// wrap create in a tx / catch. The @@index([name]) keeps the check + future
// name search fast.
model Character {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String     @db.VarChar(24)
  baseClass String     @db.VarChar(16) // engine HeroClass string: swordsman | archer | mage
  level     Int        @default(1) // cache of engine level (re-derivable)
  power     Int        @default(0) // cache of derived combat power for HOF (re-derivable; widen to BigInt if it ever exceeds 2^31)
  // M8 presence cache: the character's CURRENT zone id, stamped by /api/save
  // alongside the level/power caches (src/server/persistSave). DENORMALIZED +
  // RE-DERIVABLE from SaveState.data (engine hero.zone) — this column exists ONLY so
  // a friends-list poll can show "where is my friend" WITHOUT parsing every friend's
  // save JSON blob. Nullable = pre-M8 rows / never-saved characters read null. Online
  // vs offline and "which character is being played" are NOT stored here — they
  // derive from MAX(SaveState.lastSeen) per user (the most-recently-saved live
  // character is the active one), so no new presence column is needed.
  lastZone  String?    @db.VarChar(32) // re-derivable presence cache (engine hero.zone)
  // M7.6 "ตีบวก" (Refine): the per-character REFINE MATERIAL counter. UNLIKE
  // level/power above (denormalized re-derivable caches), this is AUTHORITATIVE —
  // it is NOT re-derivable from the save blob. It is minted ONLY by the salvage
  // endpoint (destroy dupes -> +materials) and spent ONLY by the refine endpoint
  // (materials + gold -> attempt a +level), each inside the same tx as the
  // ItemInstance/ItemEvent mutation. The save blob carries a `materials` MIRROR
  // (like the equipped-gear cache): the boot payload overrides it from THIS column
  // on load, and `persistSave` MUST NOT write it back (a client could otherwise
  // grant itself materials via a save). Owned per-character to match item ownership
  // (ItemInstance.ownerId -> Character.id); gold stays MVP-client-authoritative in
  // the save blob until the M5 gold re-derivation lands.
  materials Int        @default(0)
  // Cross-device UI/automation config (owner request 2026-07-07): the browser-
  // localStorage-owned bot/automation preferences (autoCast/autoAllocate/potion
  // thresholds/autoSell rules incl. the epic toggle/autoAdvance/autoEquip) now
  // FOLLOW THE CHARACTER instead of resetting on a phone↔PC switch. Additive +
  // NULLABLE so every pre-existing row reads null → the client keeps its own
  // localStorage/defaults (no reset). This is NOT the engine save (SAVE_VERSION)
  // and NOT authoritative game state — it is a pure preference sidecar (same tier
  // as the old localStorage keys), deliberately kept OUT of SaveData so the
  // engine-persisted config (bot targets/gold reserve, SAVE v11/v12; autoHunt) —
  // which is the single source of truth for those — is never duplicated here.
  // Validated field-by-field server-side before write (src/server/uiConfig.ts);
  // an unknown/out-of-bounds shape is rejected, never stored raw.
  uiConfig  Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime? // soft delete: slot freed, row kept for audit
  // CUTOVER APPLIED: `SaveState.characterId` is now @unique, so this is an
  // effective 1:1 — a character has AT MOST one save row.
  save      SaveState?
  // M7: gear drops are PER CHARACTER (GDD: "ของดรอปจอใครจอมัน"). ownerId of every
  // ItemInstance points here (Character.id, a never-reused cuid).
  items     ItemInstance[]
  // M8 Quest Wave B: the per-character daily-claim audit rows (anti-double-claim).
  dailyClaims DailyClaim[]

  @@index([userId]) // list an account's characters
  @@index([userId, deletedAt]) // count/enumerate LIVE slots (<=3 rule)
  @@index([name]) // app-level uniqueness check + future name search
}

// M7 Gear & Drops — the item-instance model. GDD: gear is server-authoritative
// from the FIRST item; item dupe = existential threat. This table stores only
// INSTANCES; item TEMPLATES + stats live in engine config as pure TS data and are
// referenced by `templateId` (so balance tweaks never migrate the DB).
//
// SOURCE OF TRUTH: unlike Character.level/power (denormalized caches), ItemInstance
// is authoritative — it is NOT re-derivable from the save blob. Every row is minted
// server-side inside a transaction that also appends an ItemEvent(minted). Never
// hard-delete: `deletedAt` soft-deletes (destroyed/consumed) so the audit trail
// stays intact. `id` is an opaque cuid, NEVER reused.
//
// equippedSlot enforcement (one item per slot per character): MySQL has no partial
// unique index, but its UNIQUE indexes treat NULLs as DISTINCT — so a plain
// @@unique([ownerId, equippedSlot]) allows UNLIMITED unequipped rows (equippedSlot
// NULL) while permitting AT MOST ONE non-null value per (owner, slot). That IS the
// partial-unique workaround, and it enforces the invariant at the DB layer, not just
// in app code. INVARIANT the backend must uphold: a soft-deleted item (deletedAt set)
// MUST have equippedSlot = NULL (unequip in the same tx as destroy) — otherwise a
// dead row would still occupy a slot in the unique index.
//
// claimKey (idempotency): the drop-claim endpoint sets a deterministic key per claim
// (e.g. `${characterId}:${dropRollId}`). UNIQUE + NULLABLE — a retried/duplicated
// claim request collides on the unique index and CANNOT double-mint; mints without a
// client claim (boss/admin/trade) leave it NULL (NULLs are distinct, so many allowed).
model ItemInstance {
  id           String    @id @default(cuid()) // opaque, never reused
  ownerId      String // -> Character.id (per-character ownership; NOT User)
  owner        Character @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  templateId   String    @db.VarChar(64) // engine item-template key (stats live in TS config)
  origin       String    @db.VarChar(16) // drop | boss | trade | admin
  sourceDetail String?   @db.VarChar(64) // audit: e.g. zone id / boss id / admin note
  equippedSlot String?   @db.VarChar(16) // weapon | armor | NULL(=unequipped)
  // M7.6 "ตีบวก" (Refine): the item's RO-style +level (+0..+REFINE.maxRefine).
  // Additive, default 0 -> every pre-M7.6 row is an unrefined +0 (byte-identical
  // stats). Mutated ONLY by the server-authoritative refine endpoint (the engine
  // never rolls — CLAUDE.md); success -> +1, degrade -> -1, break -> soft-delete.
  refineLevel  Int       @default(0)
  claimKey     String?   @unique // idempotency guard for the drop-claim endpoint
  acquiredAt   DateTime  @default(now())
  deletedAt    DateTime? // soft delete (destroyed/consumed); MUST NULL equippedSlot too
  events       ItemEvent[]

  @@unique([ownerId, equippedSlot]) // partial-unique via MySQL NULL-distinct: <=1 item per slot per owner; also indexes ownerId-prefix inventory reads
  @@index([templateId]) // "how many of template X exist" / codex / anti-dupe audits
}

// M7 anti-dupe backbone — APPEND-ONLY audit trail. Every state change to an item
// (mint / equip / unequip / trade / destroy) writes one row here IN THE SAME TX as
// the ItemInstance mutation. This is the ledger that makes dupes detectable and
// ownership transfers (M9 trading) provable.
//
// CONVENTION — ENFORCED BY CODE REVIEW, NOT THE DB: no code path may ever UPDATE or
// DELETE a row in this table. Inserts only. (Rows are purged only via ON DELETE
// CASCADE when a User account is hard-deleted for GDPR.)
//
// from/toCharacterId are RAW cuid strings, deliberately NOT FKs: an audit ledger must
// be immutable and independent of the entities it references (and mint has no `from`,
// destroy has no `to`). `meta` is a TEXT column holding serialized JSON (opaque, never
// queried in SQL) — kept as text, not a JSON column, to stay light on this high-write
// table.
model ItemEvent {
  id              String       @id @default(cuid())
  itemId          String
  item            ItemInstance @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type            String       @db.VarChar(16) // minted | equipped | unequipped | traded | destroyed | refined | salvaged
  // (M7.6 "ตีบวก": `salvaged` = destroyed-for-materials (meta.yield); `refined` =
  //  a refine attempt (meta {from,to,outcome,cost}; outcome "break" also soft-
  //  deletes the item, so it doubles as the destroy record for that row).
  fromCharacterId String? // raw cuid, no FK (immutable ledger)
  toCharacterId   String? // raw cuid, no FK
  meta            String?      @db.Text // serialized JSON blob (opaque audit context)
  createdAt       DateTime     @default(now())

  @@index([itemId]) // read an item's full history (ordered by createdAt in-memory)
}

// NPC buy-back (owner-approved). When a player SELLS an item instance (accidental
// sells happen), one row is recorded here so the merchant can offer it BACK within
// BUYBACK_WINDOW_DAYS (3 days, src/server/items.ts) at EXACTLY the gold credited at
// sale. Additive + ISOLATED: no existing table/column/query changes. SALVAGED items
// are NOT recorded (materials were granted → sold-only, per owner spec).
//
// Written in the SAME tx as the sell soft-delete (src/server/items.ts `sellItems`):
// one row per sold instance with its credited `price` and a SERVER-STAMPED `soldAt`
// (client clocks never trusted — mirrors SaveState.lastSeen's trust model). Buy-back
// re-creates a FRESH ItemInstance (new cuid, same templateId + refineLevel) and sets
// `restoredAt` so a row is redeemable AT MOST ONCE (atomic check-and-set, mirrors the
// refine compare-and-set). Rows past the window are lazily purged on the list read.
//
// `ownerId` = Character.id (raw cuid, matches ItemInstance.ownerId's per-character
// ownership scope) — deliberately NOT an FK relation, mirroring the
// `ItemEvent.fromCharacterId` "immutable/transient, no FK" convention: this is a
// short-lived buy-back window, not a permanent ledger, so a cascade buys nothing and
// touching the Character model is avoided. `price` is the exact gold credited at sale,
// captured then and NEVER recomputed from today's vendor config (magnitudes drift).
model SoldItem {
  id          String    @id @default(cuid())
  ownerId     String // -> Character.id (per-character; matches ItemInstance ownership)
  templateId  String    @db.VarChar(64)
  refineLevel Int       @default(0) // preserved so buy-back restores the +N item
  price       Int // exact gold credited at sale = the buy-back cost
  soldAt      DateTime // server-stamped sale time (drives the 3-day window)
  restoredAt  DateTime? // set when bought back; a row redeems at most once

  @@index([ownerId, soldAt]) // buy-back list: this owner's window rows, soonest-to-expire first + the purge sweep
}

// M7.9/M7.95 server-wide announcement feed (owner-approved design; NO
// websockets this phase — polling piggybacked on the existing autosave cycle,
// see `src/server/items.ts`'s `recentAnnouncements`). Originally refine-only
// (name kept to avoid a table rename / data-loss push); now a GENERALIZED feed
// via the additive `kind` column (default "refine" preserves every old row):
//   - "refine"   — a refine attempt SUCCEEDED at +8/+9/+10, written in the SAME
//                  tx as the refine mutation (`refineItem`, src/server/items.ts).
//   - "levelCap" — the FIRST non-suspect character to reach the level cap (M7.95,
//                  src/server/leaderboard.ts). SINGLETON: exactly-once globally.
//   - "rankOne"  — a character NEWLY took #1 on the power board (M7.95). Throttled
//                  to at most one per character per 24h.
// A row can never exist without the underlying event having actually landed.
//
// Deliberately NOT a relation to Character (raw denormalized fields, mirrors
// `ItemEvent.fromCharacterId`'s "immutable ledger, no FK" convention): this is
// a TRANSIENT feed, not a permanent audit ledger — rows are opportunistically
// pruned after ~1h (piggybacked on the write path, no cron) to keep the table
// tiny, so a cascading FK buys nothing and would only complicate a
// soft-deleted character's row.
//
// `templateId`/`refineLevel` are NULLABLE (refine kind only). For "levelCap",
// `refineLevel` carries the cap level reached (client copy interpolation); for
// "rankOne" both are null. The client localizes item names from `templateId`
// (`content.items.<templateId>.name`) and picks copy by `kind` — this table
// never bakes in a server-side locale.
//
// `singletonKey` is the EXACTLY-ONCE guard for singleton kinds: "levelCap" sets
// it to "levelCap" so the @unique index rejects any second insert (a concurrent
// second-to-cap save collides on P2002 → swallowed). Every non-singleton row
// leaves it NULL (MySQL treats NULLs as DISTINCT, so unlimited rows allowed).
model RefineAnnouncement {
  id           String   @id @default(cuid())
  kind         String   @default("refine") @db.VarChar(16) // refine | levelCap | rankOne
  characterId  String
  charName     String   @db.VarChar(24)
  templateId   String?  @db.VarChar(64) // refine kind only (localized client-side)
  refineLevel  Int? // refine kind: +level landed; levelCap kind: cap level reached
  singletonKey String?  @unique @db.VarChar(32) // exactly-once guard for singleton kinds (NULL = non-singleton)
  createdAt    DateTime @default(now())

  @@index([createdAt]) // feed reads ("last 5 minutes") + the opportunistic prune sweep
  @@index([kind, characterId, createdAt]) // rankOne 24h per-character throttle lookup
}

// M7.95 "Hall of Fame" — the ranked-boards read model. ONE row per character, a
// DENORMALIZED PROJECTION of the save blob (like Character.level/power): the
// SaveState.data JSON stays the source of truth; this row is rebuilt server-side
// on every `persistSave` (see src/server/leaderboard.ts `upsertLeaderboardEntry`)
// so a board read never touches/parses a save blob and never trusts a client
// number. Everything ranked here is derived SERVER-SIDE from the validated save:
//   - `power` is recomputed via the engine's `combatPower` over the hero rebuilt
//     WITH the AUTHORITATIVE equipped loadout (ItemInstance ledger + refine), never
//     a client-supplied power.
//   - `goldEarned`/`bossBest` are copied from the validated (migrated) save.
//   - `levelCapAt` + each `bossBest[stage].at` are SERVER-STAMPED (server wall-clock,
//     same trust model as `SaveState.lastSeen`): the engine emits 0/null, the server
//     writes the epoch. A client cannot forge an achievement time.
//   - `onlineSeconds` is an AFK accumulator: each save adds (now − lastTickAt) only
//     when that delta is a plausible in-session gap (0 < Δ < 300s), so a client
//     clock jump or a long offline gap grants nothing.
//
// `suspect` is the anti-cheat kill-switch the re-derive wave (M-later) fills:
// suspect=true rows are EXCLUDED from every board read. Default false for now.
//
// Per-stat `*At` timestamps are kept for FUTURE SEASONS (a season reset needs to
// know when each value was set). `levelCapAt` doubles as the level-board tiebreak
// (first-to-cap wins → ordered ASC). goldEarned is BigInt (lifetime idle gold can
// pass 2^31); onlineSeconds is Int (2^31 s ≈ 68y).
model LeaderboardEntry {
  id            String    @id @default(cuid())
  characterId   String    @unique // 1:1 with Character (opaque cuid)
  userId        String // owning account (my-rank + account-scoped queries)
  charName      String    @db.VarChar(24) // denormalized for a board render without a join
  cls           String    @db.VarChar(16) // Character.baseClass (immutable) — the cls board filter
  tier          Int       @default(1) // class-advancement tier (1..3), display only
  level         Int       @default(1) // level board metric
  levelCapAt    DateTime? // server-stamped when level>=levelCap first seen; level-board tiebreak (ASC = first-to-cap wins)
  power         Int       @default(0) // power board metric (engine combatPower over stats+gear+refine)
  goldEarned    BigInt    @default(0) // gold board metric (lifetime, never decremented)
  onlineSeconds Int       @default(0) // online board metric (AFK accumulator)
  bossBest      Json // Record<stage, {seconds, at(ISO)}> — full snapshot (boss board is projected to BossRecord for indexed reads)
  profile       Json // paper-doll snapshot: {loadout:{weapon,armor}, refineLevels:{weapon,armor}} — the profile view
  suspect       Boolean   @default(false) // anti-cheat: true = hidden from all boards (re-derive wave fills)
  lastTickAt    DateTime? // INTERNAL: previous save's server time — the onlineSeconds delta reference
  levelAt       DateTime? // future-seasons: when `level` was last written
  powerAt       DateTime? // future-seasons: when `power` was last written
  goldAt        DateTime? // future-seasons: when `goldEarned` was last written
  onlineAt      DateTime? // future-seasons: when `onlineSeconds` was last written
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([suspect, level, levelCapAt]) // level board (DESC level, ASC levelCapAt) + suspect exclusion
  @@index([suspect, cls, level, levelCapAt]) // cls-filtered level board
  @@index([suspect, power]) // power board
  @@index([suspect, cls, power]) // cls-filtered power board
  @@index([suspect, goldEarned]) // gold board
  @@index([suspect, cls, goldEarned]) // cls-filtered gold board
  @@index([suspect, onlineSeconds]) // online board
  @@index([suspect, cls, onlineSeconds]) // cls-filtered online board
  @@index([userId]) // account-scoped queries
}

// M7.95 boss-board projection — ONE row per (character, boss stage). The boss
// board ranks by clear time, which lives inside LeaderboardEntry.bossBest JSON;
// MySQL can't index a JSON path, so this side-table is the INDEXED projection
// (mirrors the "denormalized cache" pattern above). Written in the SAME tx as the
// LeaderboardEntry upsert (no skew). Render fields (charName/cls/tier/level) are
// denormalized so the board renders without a join; `profile` is fetched from the
// LeaderboardEntry for just the top-N ids. `at` is the SERVER-STAMPED achievement
// time carried from bossBest[stage].at. A `seconds` below the plausibility floor
// (src/server/leaderboard.ts BOSS_TIME_FLOOR) is never written (ingest drops it).
model BossRecord {
  id          String   @id @default(cuid())
  characterId String
  userId      String
  charName    String   @db.VarChar(24)
  cls         String   @db.VarChar(16)
  tier        Int      @default(1)
  level       Int      @default(1)
  stage       Int // boss stage (5/10/15/20/25/30)
  seconds     Float // clear time (lower = better); Float ordering is indexable
  at          DateTime // server-stamped achievement time
  suspect     Boolean  @default(false) // mirror of the character's suspect flag (board exclusion)
  updatedAt   DateTime @updatedAt

  @@unique([characterId, stage]) // one best per character per stage (upsert key)
  @@index([stage, suspect, seconds]) // boss board (ASC seconds) + my-rank count
  @@index([stage, cls, suspect, seconds]) // cls-filtered boss board
}

// One row per player save slot. `data` holds the versioned SaveData JSON blob
// (see src/engine/state). `lastSeen` drives capped offline-idle earnings.
// `version` mirrors SaveData.version so migrations can target rows by schema age.
//
// Today: exactly one save slot per user, so `userId` is UNIQUE. This is what lets
// `persistSave` upsert by userId (Prisma upsert needs a unique field in `where`).
// A unique constraint also provides the index, so no separate @@index is needed.
//
// M5 CUTOVER APPLIED (see docs/persistence-m5.md): saves are now PER CHARACTER.
// `characterId` is @unique (one save per character) and `userId @unique` is
// DROPPED — an account may hold up to 3 saves (one per live character). `userId`
// keeps a plain @@index for account-scoped queries + the cascade relation.
// `persistSave`/`loadSave` key off `characterId`; the active character is chosen
// via the `activeCharacterId` cookie (src/server/activeCharacter.ts).
//
// Cutover sequence that produced this state:
//   1. Backfill (prisma/backfill-characters.ts): 1 Character per existing save.
//   2. Set SaveState.characterId to that Character.id (verified distinct+non-null).
//   3. This push: characterId -> @unique, DROP userId @unique. (--accept-data-loss)
model SaveState {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // One save per character: @unique makes the load/persist path key off it and
  // provides the index (so no separate @@index needed). Nullable is retained so a
  // soft-deleted character's orphaned save can keep the (now-dangling-but-audited)
  // link; a live save always has it set.
  characterId String?    @unique
  character   Character? @relation(fields: [characterId], references: [id], onDelete: Cascade)
  version     Int
  data        Json
  lastSeen    DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId]) // account-scoped queries + cascade (was covered by @unique before)
}

// M8 Quest Wave B "Daily quests" — the anti-double-claim AUDIT gate. The daily
// roster is chosen SERVER-side (deterministic from serverDay + userId, no state),
// the ENGINE counts progress + owns the reward (client-authoritative economy, same
// trust tier as gold), and THIS table is the server's only job: a one-row-per
// (character, quest, serverDay) claim ledger. The @@unique makes a second claim of
// the same quest on the same day impossible at the DB layer (a retry/dup collides on
// P2002 → the endpoint returns 409 already_claimed) — mirrors the SoldItem/claimKey
// idempotency pattern. `serverDay` is the Asia/Bangkok (UTC+7) day-epoch integer the
// server computes from its own wall-clock (client clocks never trusted, like
// SaveState.lastSeen). NOT re-derivable from the save blob — it is authoritative.
//
// Deliberately NO reward column: rewards are engine-side economy (re-derive ceilings
// already cover client-authoritative gold), so this row records ONLY that a claim
// happened. `claimedAt` is server-stamped for a future audit sweep. Cascades from
// Character so a deleted character's claim history is purged with it.
model DailyClaim {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  questId     String    @db.VarChar(32) // engine daily catalog id (quest.daily.<id>)
  serverDay   Int // Asia/Bangkok (UTC+7) day-epoch the claim landed on
  claimedAt   DateTime  @default(now()) // server-stamped (client clocks never trusted)

  @@unique([characterId, questId, serverDay]) // at most one claim per quest per day per character
  @@index([characterId, serverDay]) // "this character's claims today" + cascade-side reads
}

// ============================================================================
// M8 "Party & Friends" — account<->account social graph. ALL binds are User<->User
// (accounts), NEVER Character: a friendship survives deleting/creating characters.
// onDelete: Cascade from both User ends so hard-deleting an account purges its rows.
// PRESENCE NOTE: "is my friend online / which character" is NOT stored in these
// tables — it derives from MAX(SaveState.lastSeen) per user + Character.lastZone
// (see the Character.lastZone comment). These tables only model the graph itself.
// ============================================================================

// A DIRECTIONAL, pending friend request (from -> to). Accept promotes it to a
// Friendship row (in one tx) and deletes this row; decline just deletes it. A row
// exists ONLY while pending, so @@unique([fromUserId, toUserId]) blocks duplicate
// spam from the same requester. The reverse-direction check (B already requested A)
// and the already-friends check are enforced in APP code before insert.
model FriendRequest {
  id         String   @id @default(cuid())
  fromUserId String
  fromUser   User     @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User     @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId]) // at most one pending request per ordered pair
  @@index([toUserId, createdAt]) // "my incoming pending requests" (newest first)
  @@index([fromUserId]) // "requests I sent" + cascade-side reads
}

// An ACCEPTED friendship — the canonical, symmetric relation stored ONCE per pair.
// CONVENTION the backend MUST uphold: userAId < userBId (lexicographic on cuid) so a
// pair has exactly ONE canonical row; @@unique([userAId, userBId]) then makes an
// A<->B / B<->A duplicate impossible at the DB layer. Removing a friend hard-deletes
// this row. "All my friends" = rows where userAId = me OR userBId = me — hence an
// index leading with each side.
model Friendship {
  id        String   @id @default(cuid())
  userAId   String // canonical: ALWAYS the lexicographically-smaller user id
  userA     User     @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId   String // canonical: ALWAYS the lexicographically-larger user id
  userB     User     @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userAId, userBId]) // one canonical row per pair (dedupes A->B / B->A)
  @@index([userAId]) // "all my friends" when I am the smaller id
  @@index([userBId]) // "all my friends" when I am the larger id
}

// Emoji ping — store-and-forward, POLLED (no websockets this phase; piggybacks the
// save/poll cycle like RefineAnnouncement). One row per ping. EPHEMERAL: the app
// DELETES rows once the recipient has seen them (seenAt set -> next poll purges);
// treat this table as a transient outbox, not an audit ledger. No cron — cleanup is
// opportunistic on the poll read (delete where seenAt IS NOT NULL, mirrors the
// RefineAnnouncement prune pattern).
model EmojiPing {
  id         String    @id @default(cuid())
  fromUserId String
  fromUser   User      @relation("EmojiPingFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User      @relation("EmojiPingTo", fields: [toUserId], references: [id], onDelete: Cascade)
  emoji      String    @db.VarChar(16) // short emoji string (pre-2020 glyphs only, per CLAUDE.md footgun #4)
  sentAt     DateTime  @default(now())
  seenAt     DateTime? // null = unseen; set on delivery, then the row is purged next poll

  @@index([toUserId, seenAt]) // "unseen pings for user X" (seenAt IS NULL filter) + purge sweep
  @@index([fromUserId]) // cascade-side reads
}

// M8 Phase 1 "Party" — a social CONTAINER (max 3), no gameplay coupling yet (the
// lockstep cohort sim is a later wave; see docs/party-design-m8.md). Membership is
// modeled as PartyMember ROWS rather than an array-on-User because it gives us both
// invariants cleanly at the DB layer:
//   - "which party am I in / my party" = a single indexed lookup by PartyMember.userId
//     (@unique → a user is in AT MOST one party, DB-ENFORCED, no app race window for
//     double-join: a second accept collides on the unique index → P2002).
//   - the <=3 cap = COUNT(PartyMember WHERE partyId) — checked inside the accept tx
//     AFTER an exclusive row-lock on the Party (tx.party.update bumps `updatedAt`),
//     which serializes concurrent accepts into the SAME party so the re-checked count
//     is authoritative (MySQL/InnoDB REPEATABLE-READ snapshot counts alone would let
//     two accepts both read 2 and both insert → the lock closes that race).
//
// `leaderUserId` is a REAL relation (onDelete: Cascade) so hard-deleting the leader's
// account dissolves the whole party (members' rows then cascade via PartyMember.partyId).
// The everyday "leader leaves" path is APP-level: leaveParty promotes the oldest
// remaining member (min joinedAt) before deleting the leader's row; the last member
// leaving deletes the Party. The leader ALSO holds a PartyMember row (they are a member).
model Party {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt // bumped to acquire the accept-race row lock
  leaderUserId String
  leader       User          @relation("PartyLeader", fields: [leaderUserId], references: [id], onDelete: Cascade)
  members      PartyMember[]

  @@index([leaderUserId]) // "parties I lead" + cascade-side reads
}

// One row per (user, party) membership. `userId @unique` is the hard guarantee that a
// user belongs to at most ONE party. Cascades from BOTH sides: deleting the Party (last
// leave / leader account purge) removes members; hard-deleting a User removes their row.
model PartyMember {
  id       String   @id @default(cuid())
  partyId  String
  party    Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId   String   @unique // a user is in AT MOST one party (DB-enforced)
  user     User     @relation("PartyMembership", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now()) // promotion order: oldest remaining member becomes leader

  @@index([partyId]) // enumerate a party's members + the <=3 COUNT
}

// Party invite — future-proofed NOW so M8 needs only ONE `prisma db push`. Minimal:
// from -> to with a status the app transitions (pending | accepted | declined |
// expired). Real-time party membership/lockstep is engine/websocket state (M8 spike),
// NOT persisted here — this table is only the invite handshake.
model PartyInvite {
  id         String   @id @default(cuid())
  fromUserId String
  fromUser   User     @relation("PartyInviteFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User     @relation("PartyInviteTo", fields: [toUserId], references: [id], onDelete: Cascade)
  status     String   @default("pending") @db.VarChar(16) // pending | accepted | declined | expired
  createdAt  DateTime @default(now())

  @@index([toUserId, status, createdAt]) // "my incoming invites" filtered by status
  @@index([fromUserId]) // cascade-side reads
}
